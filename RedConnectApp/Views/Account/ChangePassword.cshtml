@model RedConnect.ViewModels.ChangePasswordViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Change Password";
}

<div class="rc-page-header">
    <h1><i class="fas fa-lock" style="color:var(--rc-red);"></i> Change Password</h1>
    <p>Update your account password</p>
</div>

<div class="rc-card" style="max-width:500px;">
    <div class="rc-card__header">
        <h3><i class="fas fa-key" style="color:var(--rc-red);"></i> New Password</h3>
    </div>
    <div class="rc-card__body">

        @if (ViewBag.Error != null)
        {
            <div class="rc-alert rc-alert--error mb-3">
                <i class="fas fa-exclamation-circle"></i> @ViewBag.Error
            </div>
        }
        @if (ViewBag.Success != null)
        {
            <div class="rc-alert rc-alert--success mb-3">
                <i class="fas fa-check-circle"></i> @ViewBag.Success
            </div>
        }

        <form method="post" onsubmit="return rcValidatePwdChange()">
            <div class="mb-3">
                <label class="rc-form-label"><i class="fas fa-lock"></i> Current Password</label>
                <div class="rc-input-wrap">
                    <input type="password" class="rc-input" id="currentPwd" name="CurrentPassword"
                           placeholder="Enter current password" required style="padding-right:3rem;">
                    <span class="rc-pwd-toggle" onclick="rcTogglePwd('currentPwd','curPwdIcon')">
                        <i class="fas fa-eye" id="curPwdIcon"></i>
                    </span>
                </div>
            </div>

            <div class="mb-3">
                <label class="rc-form-label"><i class="fas fa-lock"></i> New Password</label>
                <div class="rc-input-wrap">
                    <input type="password" class="rc-input" id="newPwd" name="NewPassword"
                           placeholder="Min. 8 characters" required
                           oninput="rcStrength(this.value)" style="padding-right:3rem;">
                    <span class="rc-pwd-toggle" onclick="rcTogglePwd('newPwd','newPwdIcon')">
                        <i class="fas fa-eye" id="newPwdIcon"></i>
                    </span>
                </div>
                <div class="rc-strength-bar"><div class="rc-strength-fill" id="strengthFill"></div></div>
            </div>

            <div class="mb-4">
                <label class="rc-form-label"><i class="fas fa-lock"></i> Confirm New Password</label>
                <div class="rc-input-wrap">
                    <input type="password" class="rc-input" id="confirmPwd" name="ConfirmPassword"
                           placeholder="Re-enter new password" required
                           oninput="rcCheckMatch()" style="padding-right:3rem;">
                    <span class="rc-pwd-toggle" onclick="rcTogglePwd('confirmPwd','confPwdIcon')">
                        <i class="fas fa-eye" id="confPwdIcon"></i>
                    </span>
                </div>
                <div id="matchMsg" style="font-size:0.8rem; margin-top:0.3rem;"></div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="rc-btn rc-btn--primary">
                    <i class="fas fa-save"></i> Update Password
                </button>
                <a href="/Dashboard" class="rc-btn rc-btn--outline">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function rcTogglePwd(id, iconId) {
    const inp = document.getElementById(id);
    const ico = document.getElementById(iconId);
    const isPass = inp.type === 'password';
    inp.type = isPass ? 'text' : 'password';
    ico.classList.toggle('fa-eye', !isPass);
    ico.classList.toggle('fa-eye-slash', isPass);
}
function rcStrength(val) {
    const fill = document.getElementById('strengthFill');
    fill.className = 'rc-strength-fill';
    if (!val) return;
    fill.classList.add(val.length < 6 ? 'weak' : val.length < 10 ? 'medium' : 'strong');
}
function rcCheckMatch() {
    const pw  = document.getElementById('newPwd').value;
    const cpw = document.getElementById('confirmPwd').value;
    const msg = document.getElementById('matchMsg');
    if (!cpw) { msg.textContent = ''; return; }
    msg.style.color = pw === cpw ? '#198754' : '#dc3545';
    msg.textContent  = pw === cpw ? '✓ Passwords match' : '✗ Passwords do not match';
}
function rcValidatePwdChange() {
    const pw  = document.getElementById('newPwd').value;
    const cpw = document.getElementById('confirmPwd').value;
    if (pw !== cpw) {
        rcCheckMatch();
        return false;
    }
    return true;
}
</script>
}
