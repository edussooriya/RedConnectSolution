@model RedConnect.ViewModels.UserViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Config
@{
    Layout = "_Layout";
    ViewData["Title"] = "My Profile";
}

<div class="rc-page-header">
    <h1><i class="fas fa-user-edit" style="color:var(--rc-red);"></i> My Profile</h1>
    <p>Update your personal information and donation preferences</p>
</div>

<div class="rc-card">
    <div class="rc-card__header">
        <h3><i class="fas fa-id-card" style="color:var(--rc-red);"></i> Profile Details</h3>
        <span class="rc-badge rc-badge--blood">
            <i class="fas fa-tint"></i> @(Model.BloodGroup ?? "No Blood Group")
        </span>
    </div>
    <div class="rc-card__body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="UserTypeId" />
            <input type="hidden" asp-for="Active" />
            <input type="hidden" asp-for="DonatedLat" />
            <input type="hidden" asp-for="DonatedLng" />

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="rc-form-label"><i class="fas fa-user"></i> Full Name</label>
                    <input asp-for="Name" class="rc-input" placeholder="Full name" />
                </div>
                <div class="col-md-6">
                    <label class="rc-form-label"><i class="fas fa-envelope"></i> Email</label>
                    <input asp-for="Email" class="rc-input" type="email" />
                </div>
                <div class="col-md-6">
                    <label class="rc-form-label"><i class="fas fa-id-card"></i> NIC</label>
                    <input asp-for="NIC" class="rc-input" placeholder="National ID" />
                </div>
                <div class="col-md-6">
                    <label class="rc-form-label"><i class="fas fa-phone"></i> Phone</label>
                    <input asp-for="Phone" class="rc-input" placeholder="Phone number" />
                </div>
                <div class="col-md-6">
                    <label class="rc-form-label"><i class="fas fa-map-marker-alt"></i> Address</label>
                    <input asp-for="Address" class="rc-input" placeholder="Your address" />
                </div>
                <div class="col-md-6">
                    <label class="rc-form-label"><i class="fas fa-tint"></i> Blood Group</label>
                    <select asp-for="BloodGroup" class="rc-select">
                        <option value="">-- Select Blood Group --</option>
                        @foreach (var bg in new[] { "A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-" })
                        {
                            <option value="@bg">@bg</option>
                        }
                    </select>
                </div>
                <div class="col-12">
                    <label class="rc-form-label">
                        <i class="fas fa-location-crosshairs"></i> Available Location
                    </label>
                    <input asp-for="LocationText" id="locationSearch" class="rc-input"
                           placeholder="Type a location (e.g., Colombo, Sri Lanka)" autocomplete="off" />
                    <input asp-for="AvailableLat" id="lat" type="hidden" />
                    <input asp-for="AvailableLng" id="lng" type="hidden" />
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input type="checkbox" asp-for="Concent" class="form-check-input" id="concent">
                        <label class="form-check-label text-muted" for="concent" style="font-size:0.875rem;">
                            Show my contact number publicly on the Donor Map
                        </label>
                    </div>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2 flex-wrap">
                <button type="submit" class="rc-btn rc-btn--primary">
                    <i class="fas fa-save"></i> Save Changes
                </button>
                <a href="/Map/Donors" class="rc-btn rc-btn--outline">
                    <i class="fas fa-map-marked-alt"></i> View Donor Map
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script src="https://maps.googleapis.com/maps/api/js?key=@Config["Google:MapsApiKey"]&libraries=places"></script>
<script>
window.addEventListener('load', function () {
    const input = document.getElementById('locationSearch');
    const ac = new google.maps.places.Autocomplete(input, {
        types: ['geocode'],
        componentRestrictions: { country: 'lk' }
    });
    ac.addListener('place_changed', function () {
        const place = ac.getPlace();
        if (!place.geometry) return;
        document.getElementById('lat').value = place.geometry.location.lat();
        document.getElementById('lng').value = place.geometry.location.lng();
    });
});
</script>
}
