
    <!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Red Connect | Blood Donation System</title>

        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

        <style>

            body {
                font-family: 'Segoe UI', sans-serif;
                background-color: #ffffff;
            }

            /* NAVBAR */
            .navbar {
                background: rgba(255, 0, 0, 0.15);
                backdrop-filter: blur(10px);
            }

            .navbar-brand {
                color: #fff;
                font-weight: bold;
                font-size: 1.3rem;
            }

                .navbar-brand i {
                    color: #ff4d4d;
                }

            .nav-link {
                color: #fff !important;
            }

            /* HERO */
            .hero {
                background: linear-gradient(rgba(139,0,0,0.7), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1588776814546-ec7e2b97b6b3');
                background-size: cover;
                background-position: center;
                color: white;
                height: 100vh;
                display: flex;
                align-items: center;
                text-align: center;
            }

                .hero h1 {
                    font-size: 3.5rem;
                    font-weight: bold;
                }

                .hero p {
                    max-width: 700px;
                    margin: auto;
                }

            /* BUTTONS */
            .btn-main {
                padding: 12px 30px;
                border-radius: 30px;
                margin: 10px;
                transition: 0.3s;
            }

            .btn-danger {
                background: linear-gradient(45deg, #ff1a1a, #cc0000);
                border: none;
            }

                .btn-danger:hover {
                    background: linear-gradient(45deg, #cc0000, #990000);
                    transform: translateY(-2px);
                }

            .btn-outline-light:hover {
                transform: translateY(-2px);
            }

            /* ABOUT */
            .about {
                padding: 80px 20px;
            }

                .about h2 {
                    color: #cc0000;
                    font-weight: bold;
                }

            /* FEATURES */
            .features {
                background: #fff5f5;
                padding: 80px 20px;
                text-align: center;
            }

            .feature-box {
                padding: 30px;
                border-radius: 15px;
                transition: 0.3s;
            }

                .feature-box:hover {
                    background: white;
                    box-shadow: 0 5px 20px rgba(0,0,0,0.1);
                    transform: translateY(-5px);
                }

                .feature-box i {
                    color: #e60000;
                }

            /* MAP */
            .map-section {
                padding: 80px 20px;
            }

            /* CTA */
            .bg-danger {
                background: linear-gradient(45deg, #e60000, #990000) !important;
            }

            /* FOOTER */
            .footer {
                background: #111;
                color: white;
                text-align: center;
                padding: 20px;
            }

        </style>
    </head>
    

<body>
    <div class="container mt-5 pt-4">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>
</body>
</html>
