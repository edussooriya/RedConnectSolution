@{
    Layout = "~/Views/Shared/_LandingLayout.cshtml";
}




    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container">
            <a class="navbar-brand" href="#"><i class="fas fa-heart-pulse"></i> Red Connect</a>
            <div class="ms-auto">
                <a href="/Account/Login" class="btn btn-outline-light btn-sm">Login</a>
                <a href="/Account/Register" class="btn btn-danger btn-sm">Sign Up</a>
            </div>
        </div>
    </nav>

    <!-- HERO -->
    <section class="hero">
        <div class="container">
            <h1>Save Lives with Smart Blood Donation</h1>
            <p class="lead">
                Connecting donors, hospitals, and blood banks in real-time
                to ensure faster emergency response and life-saving support.
            </p>

            <a href="/Account/Register" class="btn btn-danger btn-main">Get Started</a>
            <a href="/Account/Login" class="btn btn-outline-light btn-main">Login</a>
        </div>
    </section>

    <!-- ABOUT -->
    <section class="about text-center">
    <div class="container">
            <h2>About Red Connect</h2>
            <p>
                Red Connect is a smart blood donation platform designed to solve
                critical blood shortages by enabling real-time donor tracking,
                emergency alerts, and seamless coordination between medical institutions.
            </p>
        </div>
    </section>

    <!-- FEATURES -->
    <section class="features">
        <div class="container">
            <h2 class="text-danger">System Features</h2>
            <div class="row mt-4">

                <div class="col-md-4 feature-box">
                    <i class="fas fa-map-marker-alt fa-3x"></i>
                    <h5 class="mt-3">Location-Based Matching</h5>
                    <p>Find nearest donors and blood banks instantly.</p>
                </div>

                <div class="col-md-4 feature-box">
                    <i class="fas fa-bell fa-3x"></i>
                    <h5 class="mt-3">Emergency Alerts</h5>
                    <p>Real-time notifications for urgent blood needs.</p>
                </div>

                <div class="col-md-4 feature-box">
                    <i class="fas fa-database fa-3x"></i>
                    <h5 class="mt-3">Centralized System</h5>
                    <p>Secure and scalable donor data management.</p>
                </div>

            </div>
        </div>
    </section>

    <!-- MAP -->
    <section class="map-section text-center">
        <div class="container">
            <h2>Blood Bank Locations</h2>
            <p>Explore nearby donation centers in real-time</p>

            <iframe src="https://maps.google.com/maps?q=colombo%20national%20blood%20bank&t=&z=12&ie=UTF8&iwloc=&output=embed"
                    width="100%"
                    height="400"
                    style="border-radius:10px; border:0;">
            </iframe>
        </div>
    </section>

    <!-- CTA -->
    <section class="text-center p-5 bg-danger text-white">
        <h2 class="fw-bold">Save Lives Together</h2>
        <p class="lead">Join our community of heroes who donate blood and save lives every day</p>
        <a href="/Account/Register" class="btn btn-light">Create Account</a>
    </section>

    <!-- FOOTER -->
    <footer class="footer">
        <p>© 2026 Red Connect | MSc IT Project</p>
    </footer>

