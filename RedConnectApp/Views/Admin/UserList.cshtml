@model List<RedConnect.ViewModels.AdminUserListViewModel>
@{
    Layout = "_Layout";
    ViewData["Title"] = "User Management";
    var filter = ViewBag.Filter as string ?? "all";
}

<div class="rc-page-header">
    <h1><i class="fas fa-users-cog" style="color:var(--rc-red);"></i> User Management</h1>
    <p>View, create and manage all user accounts</p>
</div>

<!-- Filter Tabs -->
<div class="rc-card mb-3">
    <div class="rc-card__body" style="padding:0.75rem 1.5rem;">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div class="d-flex gap-2 flex-wrap">
                <a href="/Admin/UserList"
                   class="rc-btn rc-btn--sm @(filter == "all" ? "rc-btn--primary" : "rc-btn--outline")">
                    All <span class="ms-1 fw-bold">@ViewBag.TotalAll</span>
                </a>
                <a href="/Admin/UserList?filter=donors"
                   class="rc-btn rc-btn--sm @(filter == "donors" ? "rc-btn--primary" : "rc-btn--outline")">
                    Donors <span class="ms-1 fw-bold">@ViewBag.TotalDonors</span>
                </a>
                <a href="/Admin/UserList?filter=staff"
                   class="rc-btn rc-btn--sm @(filter == "staff" ? "rc-btn--primary" : "rc-btn--outline")">
                    Staff / Admin <span class="ms-1 fw-bold">@ViewBag.TotalStaff</span>
                </a>
                <a href="/Admin/UserList?filter=inactive"
                   class="rc-btn rc-btn--sm @(filter == "inactive" ? "rc-btn--primary" : "rc-btn--outline")">
                    Inactive <span class="ms-1 fw-bold">@ViewBag.TotalInactive</span>
                </a>
            </div>
            <a href="/Admin/CreateUser" class="rc-btn rc-btn--primary rc-btn--sm">
                <i class="fas fa-user-plus"></i> Create User
            </a>
        </div>
    </div>
</div>

<!-- User Table -->
<div class="rc-card">
    <div class="rc-card__header">
        <h3><i class="fas fa-table-list" style="color:var(--rc-red);"></i> Accounts</h3>
        <span class="rc-badge rc-badge--blood">@Model.Count shown</span>
    </div>
    <div class="rc-table-wrap">
        <table class="rc-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Blood</th>
                    <th>Status</th>
                    <th>Joined</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4" style="font-size:0.9rem;">
                            No accounts found.
                        </td>
                    </tr>
                }
                @foreach (var u in Model)
                {
                    <tr style="@(!u.Active ? "opacity:0.55;" : "")">
                        <td style="font-size:0.82rem; color:var(--rc-gray-500);">@u.UserId</td>
                        <td><strong>@u.Name</strong></td>
                        <td style="font-size:0.85rem; color:var(--rc-gray-700);">@u.Email</td>
                        <td>
                            @if (u.UserTypeId == 0)
                            {
                                <span class="rc-badge rc-badge--verified">
                                    <i class="fas fa-heart"></i> Donor
                                </span>
                            }
                            else
                            {
                                <span class="rc-badge" style="background:#e7f0ff;color:#0d6efd;">
                                    <i class="fas fa-shield-halved"></i> @u.UserTypeName
                                </span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(u.BloodGroup))
                            {
                                <span class="rc-badge rc-badge--blood">
                                    <i class="fas fa-tint"></i> @u.BloodGroup
                                </span>
                            }
                            else
                            {
                                <span style="color:var(--rc-gray-500); font-size:0.82rem;">—</span>
                            }
                        </td>
                        <td>
                            @if (!u.Active)
                            {
                                <span class="rc-badge" style="background:#f8d7da;color:#842029;">
                                    <i class="fas fa-ban"></i> Inactive
                                </span>
                            }
                            else if (u.UserTypeId == 0 && u.Verified)
                            {
                                <span class="rc-badge rc-badge--verified">
                                    <i class="fas fa-circle-check"></i> Verified
                                </span>
                            }
                            else if (u.UserTypeId == 0)
                            {
                                <span class="rc-badge rc-badge--pending">
                                    <i class="fas fa-clock"></i> Pending
                                </span>
                            }
                            else
                            {
                                <span class="rc-badge rc-badge--verified">
                                    <i class="fas fa-circle-check"></i> Active
                                </span>
                            }
                        </td>
                        <td style="font-size:0.82rem; color:var(--rc-gray-500);">
                            @u.CreatedOn.ToString("MMM dd, yyyy")
                        </td>
                        <td>
                            <div class="d-flex gap-1 flex-wrap">
                                <a href="/Admin/EditUser/@u.UserId" class="rc-btn rc-btn--sm rc-btn--outline">
                                    <i class="fas fa-pen"></i> Edit
                                </a>
                                <form asp-action="ToggleActive" asp-controller="Admin" method="post"
                                      style="display:inline;"
                                      onsubmit="return confirm('@(u.Active ? "Deactivate" : "Reactivate") this account?')">
                                    <input type="hidden" name="userId" value="@u.UserId" />
                                    <input type="hidden" name="currentActive" value="@u.Active.ToString().ToLower()" />
                                    <button type="submit"
                                            class="rc-btn rc-btn--sm"
                                            style="@(u.Active ? "background:#dc3545;color:white;" : "background:#198754;color:white;")">
                                        <i class="fas @(u.Active ? "fa-ban" : "fa-rotate-left")"></i>
                                        @(u.Active ? "Deactivate" : "Reactivate")
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
